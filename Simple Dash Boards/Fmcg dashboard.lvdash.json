    {
      "name": "top_5_products",
      "displayName": "Top 5 Products by Sales",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(total_amount_inr) as total_sales\n",
        "FROM\n",
        "  fmcg.gold.one_big_table\n",
        "WHERE\n",
        "  year = 2025\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_sales DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "monthly_product_sales",
      "displayName": "Monthly Product Sales Growth",
      "queryLines": [
        "WITH top_products AS (\n",
        "  SELECT\n",
        "    product\n",
        "  FROM\n",
        "    fmcg.gold.one_big_table\n",
        "  WHERE\n",
        "    year = 2025\n",
        "  GROUP BY\n",
        "    product\n",
        "  ORDER BY\n",
        "    SUM(total_amount_inr) DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  date,\n",
        "  month_name,\n",
        "  product,\n",
        "  SUM(total_amount_inr) as monthly_sales\n",
        "FROM\n",
        "  fmcg.gold.one_big_table\n",
        "WHERE\n",
        "  year = 2025\n",
        "  AND product IN (\n",
        "    SELECT\n",
        "      product\n",
        "    FROM\n",
        "      top_products\n",
        "  )\n",
        "GROUP BY\n",
        "  date,\n",
        "  month_name,\n",
        "  product\n",
        "ORDER BY\n",
        "  date,\n",
        "  product"
      ]
    }
  ],
